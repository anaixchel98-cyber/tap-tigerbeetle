{
  // https://code.visualstudio.com/docs/editor/debugging
  "version": "0.2.0",
  "configurations": [
    {
      "name": "tap-tigerbeetle discover",
      "type": "python",
      "request": "launch",
      "program": "../tap_tigerbeetle/tap.py",
      "cwd": "${workspaceFolder}/.secrets",
      "args": ["--config", "config.json", "--discover"],
      "console": "integratedTerminal",
      "python": "${workspaceFolder}/.venv/Scripts/python.exe"
    },
    {
      "name": "tap-tigerbeetle get",
      "type": "python",
      "request": "launch",
      "justMyCode": false,
      "program": "../tap_tigerbeetle/tap.py",
      "cwd": "${workspaceFolder}/.secrets",
      "args": [
        "--config",
        "config.json",
        "--catalog",
        "catalog.json",
        "--state",
        "state.json"
      ],
      "console": "integratedTerminal",
      "python": "${workspaceFolder}/.venv/Scripts/python.exe"
    }
  ]
}
