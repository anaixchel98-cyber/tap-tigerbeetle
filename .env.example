# Tigerbeetle Configuration
# Copy this file to .env and fill in your actual values.
# Variable names follow the tap's setting keys; run `tap-tigerbeetle --about` for the
# authoritative list.

# Required: Access key used to authenticate against Tigerbeetle
TAP_TIGERBEETLE_ACCESS_KEY=your_access_key_here

# Optional: The earliest record date to sync (ISO-8601)
TAP_TIGERBEETLE_START_DATE=2023-01-01T00:00:00Z

# Optional: API base URL (defaults to https://api.mysample.com)
TAP_TIGERBEETLE_API_URL=https://api.mysample.com
